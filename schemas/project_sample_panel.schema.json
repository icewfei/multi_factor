{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "multifactor/project_sample_panel.schema.json",
  "title": "Project Sample Panel",
  "type": "object",
  "required": [
    "snapshot_id",
    "instrument",
    "signal_date",
    "label_defined",
    "entry_tradeable",
    "planned_exit_tradeable",
    "signal_emittable",
    "ranking_eligible_D0"
  ],
  "properties": {
    "snapshot_id": { "type": "string" },
    "instrument": { "type": "string" },
    "signal_date": { "type": "string" },
    "entry_date": { "type": ["string", "null"] },
    "planned_exit_date": { "type": ["string", "null"] },
    "label_defined": { "type": "boolean" },
    "entry_tradeable": { "type": "boolean" },
    "planned_exit_tradeable": { "type": "boolean" },
    "actually_exited": { "type": "boolean" },
    "feature_ready_D0": { "type": "boolean" },
    "price_window_ready_D0": { "type": "boolean" },
    "core_features_complete_D0": { "type": "boolean" },
    "pit_state_complete_D0": { "type": "boolean" },
    "base_universe_member_D0": { "type": "boolean" },
    "rules_filter_pass_D0": { "type": "boolean" },
    "state_filter_pass_D0": { "type": "boolean" },
    "universe_eligible_D0": { "type": "boolean" },
    "signal_emittable": { "type": "boolean" },
    "ranking_eligible_D0": { "type": "boolean" },
    "train_mask_v1": { "type": "boolean" },
    "eval_mask_v1": { "type": "boolean" },
    "train_mask_conservative": { "type": "boolean" },
    "eval_mask_conservative": { "type": "boolean" },
    "mask_reason_json": { "type": ["string", "null"] },
    "entry_filled_D1_shared_proxy": { "type": ["boolean", "null"] },
    "backtest_executable_shared_proxy": { "type": ["boolean", "null"] }
  }
}
