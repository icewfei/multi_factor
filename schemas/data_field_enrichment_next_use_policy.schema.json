{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "multifactor/data_field_enrichment_next_use_policy.schema.json",
  "title": "Data Field Enrichment Next Use Policy",
  "description": "Governance policy for conditional use of data_field_enrichment_v1 outputs. Defines allowed_fields, blocked_fields, disclosure requirements, and fail-fast downstream boundaries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_version",
    "entity_name",
    "layer_type",
    "conditional_pass",
    "no_frozen_test_access",
    "allowed_fields",
    "blocked_fields",
    "conditional_fields",
    "required_disclosure",
    "forbidden_downstream_usage",
    "fail_fast_conditions"
  ],
  "properties": {
    "policy_version": {
      "type": "string",
      "const": "data_field_enrichment_v1_next_use_policy"
    },
    "entity_name": {
      "type": "string",
      "const": "enriched_security_state_daily_v1"
    },
    "layer_type": {
      "type": "string",
      "const": "conditional enrichment layer"
    },
    "conditional_pass": {
      "type": "boolean",
      "const": true
    },
    "no_frozen_test_access": {
      "type": "boolean",
      "const": true
    },
    "allowed_fields": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocked_fields": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "conditional_fields": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_disclosure": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_downstream_usage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fail_fast_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
