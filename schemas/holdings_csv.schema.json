{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "multifactor/holdings_csv.schema.json",
  "title": "Holdings CSV",
  "type": "object",
  "required": [
    "run_id",
    "attempt_id",
    "position_id",
    "instrument",
    "signal_date",
    "entry_date",
    "planned_exit_date",
    "actual_exit_date",
    "target_weight_D0",
    "entry_fill_weight"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "attempt_id": { "type": "string" },
    "run_type": { "type": ["string", "null"] },
    "snapshot_id": { "type": "string" },
    "position_id": { "type": "string" },
    "instrument": { "type": "string" },
    "signal_date": { "type": "string" },
    "entry_date": { "type": "string" },
    "planned_exit_date": { "type": "string" },
    "actual_exit_date": { "type": "string" },
    "actual_exit_event_type": { "type": ["string", "null"] },
    "actual_exit_price_field": { "type": ["string", "null"] },
    "actual_sell_price": { "type": ["number", "null"] },
    "exit_delay_days": { "type": ["integer", "null"] },
    "execution_delayed_realized_return": { "type": ["number", "null"] },
    "execution_path_status": { "type": ["string", "null"] },
    "target_weight_D0": { "type": ["number", "null"] },
    "entry_fill_weight": { "type": ["number", "null"] },
    "cohort_capital_fraction": { "type": ["number", "null"] },
    "entry_filled_D1": { "type": "boolean" },
    "entry_filled_reason": { "type": ["string", "null"] },
    "backtest_executable": { "type": "boolean" },
    "terminal_event_flag": { "type": ["boolean", "null"] },
    "terminal_event_type": { "type": ["string", "null"] },
    "terminal_event_date": { "type": ["string", "null"] },
    "terminal_exit_pricing_method": { "type": ["string", "null"] },
    "pricing_policy_version": { "type": ["string", "null"] },
    "source_repair_flag": { "type": ["boolean", "null"] },
    "terminal_exit_approximation_flag": { "type": ["boolean", "null"] },
    "terminal_exit_conservative_flag": { "type": ["boolean", "null"] }
  }
}
